local spamIndicator = Drawing.new("Text")
spamIndicator.Visible = false
spamIndicator.Size = 20
spamIndicator.Font = 2
spamIndicator.Center = true
spamIndicator.Outline = true
spamIndicator.OutlineColor = Color3.fromRGB(0, 0, 0)
spamIndicator.Color = Color3.fromRGB(255, 50, 255)
spamIndicator.Text = "[ SPAM ACTIVE ]"

local function UpdateCircle(root, distance, state)
    if not SETTINGS.Visuals then
        circle.Visible = false
        circle2.Visible = false
        return
    end
    local camera = workspace.CurrentCamera
    local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)
    if not onScreen then
        circle.Visible = false
        circle2.Visible = false
        return
    end
    local pos2D = Vector2.new(screenPos.X, screenPos.Y)
    local scaledRadius = math.clamp(1000 / math.max(distance, 1), 20, 120)
    circle.Position = pos2D
    circle.Radius = scaledRadius
    circle.Visible = true
    circle2.Position = pos2D
    circle2.Radius = scaledRadius * 0.5
    circle2.Visible = true
    if state == "spam" then
        circle.Color = Color3.fromRGB(255, 50, 255)
        circle2.Color = Color3.fromRGB(200, 0, 255)
    elseif state == "clash" then
        circle.Color = Color3.fromRGB(255, 0, 0)
        circle2.Color = Color3.fromRGB(255, 100, 0)
    elseif state == "target" then
        circle.Color = Color3.fromRGB(0, 255, 255)
        circle2.Color = Color3.fromRGB(0, 150, 255)
    else
        circle.Color = Color3.fromRGB(150, 240, 255)
        circle2.Color = Color3.fromRGB(100, 180, 255)
    end
end

local function StartSpam()
    if isSpamming then return end
    isSpamming = true
    task.spawn(function()
        while isSpamming and SETTINGS.AutoSpam do
            FireClick()
            task.wait(SETTINGS.SpamInterval)
        end
        isSpamming = false
    end)
end

local function StopSpam()
    isSpamming = false
end

