-- Network stats
local NetworkStats = nil
pcall(function()
    NetworkStats = Stats:FindFirstChild("Network")
        and Stats.Network:FindFirstChild("ServerStatsItem")
        and Stats.Network.ServerStatsItem:FindFirstChild("Data Ping")
end)

local function GetPing()
    local ping = 0.04
    pcall(function()
        if NetworkStats then
            ping = math.clamp(NetworkStats.Value / 1000, 0.005, 0.5)
        end
    end)
    return ping
end

local function UpdateAdaptivePing(ping)
    if not SETTINGS.AdaptivePing then return end
    table.insert(pingHistory, ping)
    if #pingHistory > pingHistoryMax then table.remove(pingHistory, 1) end
    local sum = 0
    for _, v in ipairs(pingHistory) do sum = sum + v end
    adaptivePingOffset = SETTINGS.PingBasedOffset + ((sum / #pingHistory) * 0.5)
end

local function GetBall()
    if not BallsFolder then return nil end
    local children = BallsFolder:GetChildren()
    for i = 1, #children do
        local v = children[i]
        local ok, result = pcall(function() return v:GetAttribute("realBall") == true end)
        if ok and result then return v end
    end
    for i = 1, #children do
        local v = children[i]
        if v:IsA("BasePart") then
            local ok, mag = pcall(function() return v.AssemblyLinearVelocity.Magnitude end)
            if ok and mag and mag > 15 then return v end
        end
    end
    return nil
end

local function IsTargeted()
    local char = Player.Character
    if not char then return false end
    local ok, attr = pcall(function() return char:GetAttribute("Targeted") == true end)
    if ok and attr then return true end
    local highlight = char:FindFirstChildWhichIsA("Highlight")
    if highlight and highlight.Parent == char then return true end
    return false
end

-- Fire click with optional F key mode
local function FireClick()
    pcall(function()
        if SETTINGS.UseKeyParry then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.016)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        else
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    end)
end

-- Curve mode prediction
local function GetPredictedPosition(ball, velocity, ping)
    if not SETTINGS.PredictPosition then return ball.Position end
    local mode = SETTINGS.CurveMode
    local gravity = workspace.Gravity
    local basePos = ball.Position
        + (velocity * ping)
        + Vector3.new(0, -0.5 * gravity * ping * ping, 0)

    if mode == "Camera" then
        local camDir = workspace.CurrentCamera.CFrame.LookVector
        return basePos + camDir * 0.5
    elseif mode == "Random" then
        return basePos + Vector3.new(
            math.random(-2, 2) * 0.1,
            math.random(-2, 2) * 0.1,
            math.random(-2, 2) * 0.1
        )
    elseif mode == "Accelerated" then
        local accel = (velocity - lastBallVel) / math.max(ping, 0.001)
        return basePos + (accel * 0.5 * ping * ping)
    elseif mode == "Backwards" then
        return basePos - velocity * ping * 0.3
    elseif mode == "Slow" then
        return ball.Position + velocity * (ping * 0.5)
    elseif mode == "High" then
        return basePos + Vector3.new(0, 5, 0)
    end
    return basePos
end

local function SendClick(ball)
    if not SETTINGS.AutoParry or IsParrying then return end
    local now = tick()
    if LastBallHit == ball and (now - LastClick) < 0.5 then return end
    if (now - LastClick) < 0.1 then return end -- increased from 0.05
    IsParrying = true
    LastClick = now
    LastBallHit = ball
    FireClick()
    task.delay(0.1, function() IsParrying = false end)
end

-- Visual part
local r, m
local function InitVisuals()
    local old = workspace:FindFirstChild("AeloeSmartCircle")
    if old then old:Destroy() end
    r = Instance.new("Part")
    r.Name = "AeloeSmartCircle"
    r.Parent = workspace
    r.Anchored = true
    r.CanCollide = false
    r.CanQuery = false
    r.CanTouch = false
    r.CastShadow = false
    r.Transparency = 1
    r.Material = Enum.Material.Neon
    m = Instance.new("SpecialMesh", r)
    m.MeshId = "rbxassetid://3270017"
end

if SETTINGS.Visuals then
    InitVisuals()
end

local function UpdateVisuals(root, distance, state)
    if not SETTINGS.Visuals or not r then return end
    
    -- Small wait so it follows character smoothly
    task.wait(0.01)
    
    r.CFrame = root.CFrame * CFrame.new(0, -2.6, 0) * CFrame.Angles(math.rad(90), 0, 0)
    local targetSize = math.clamp(distance * 0.8, 5, 65)
    m.Scale = m.Scale:Lerp(Vector3.new(targetSize, targetSize, 0.5), 0.5)

    if state == "clash" then
        r.Color = Color3.fromRGB(255, 0, 0)
        r.Transparency = 0.05
    elseif state == "target" then
        r.Color = Color3.fromRGB(0, 255, 255)
        r.Transparency = 0.1
    else
        r.Color = Color3.fromRGB(150, 240, 255)
        r.Transparency = 0.5
    end
end

-- Ball Trail
local function RemoveBallTrail()
    if ballTrailObj then
        pcall(function() ballTrailObj:Destroy() end)
        ballTrailObj = nil
    end
end

local function AddBallTrail(ball)
    RemoveBallTrail()
    if not ball then return end

    local attachment0 = Instance.new("Attachment")
    attachment0.Parent = ball
    local attachment1 = Instance.new("Attachment")
    attachment1.Position = Vector3.new(0, 0, -ball.Size.Z / 2)
    attachment1.Parent = ball

    local trail = Instance.new("Trail")
    trail.Attachment0 = attachment0
    trail.Attachment1 = attachment1
    trail.Lifetime = 0.5
    trail.MinLength = 0
    trail.FaceCamera = true
    trail.Color = ColorSequence.new(SETTINGS.TrailColor1, SETTINGS.TrailColor2)
    trail.Transparency = NumberSequence.new(0, 1)
    trail.Parent = ball
    ballTrailObj = trail
end

if BallsFolder then
    BallsFolder.ChildAdded:Connect(function()
