-- Auto spam
local function StartSpam()
    if isSpamming then return end
    isSpamming = true
    task.spawn(function()
        while isSpamming and SETTINGS.AutoSpam do
            FireClick()
            task.wait(SETTINGS.SpamInterval)
        end
        isSpamming = false
    end)
end

local function StopSpam()
    isSpamming = false
end

