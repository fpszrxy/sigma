InitVisuals()

local function UpdateCircle(root, distance, state)
    if not SETTINGS.Visuals then
        circle.Visible = false
        circle2.Visible = false
        return
    end

    local camera = workspace.CurrentCamera
    local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)

    if not onScreen then
        circle.Visible = false
        circle2.Visible = false
        return
    end

    local pos2D = Vector2.new(screenPos.X, screenPos.Y)

    -- Scale circle size based on distance
    local scaledRadius = math.clamp(1000 / math.max(distance, 1), 20, 120)

    circle.Position = pos2D
    circle.Radius = scaledRadius
    circle.Visible = true

    circle2.Position = pos2D
    circle2.Radius = scaledRadius * 0.5
    circle2.Visible = true

    if state == "clash" then
        circle.Color = CLASH_COLOR
        circle2.Color = Color3.fromRGB(255, 100, 0)
    elseif state == "target" then
        circle.Color = TARGET_COLOR
        circle2.Color = Color3.fromRGB(0, 150, 255)
    elseif state == "spam" then
        circle.Color = Color3.fromRGB(255, 50, 255)
        circle2.Color = Color3.fromRGB(255, 0, 255)
    else
        circle.Color = Color3.fromRGB(150, 240, 255)
        circle2.Color = Color3.fromRGB(100, 180, 255)
    end
end

local function GetBall()
    if not BallsFolder then return nil end
    local children = BallsFolder:GetChildren()
    for i = 1, #children do
        local v = children[i]
        local ok, result = pcall(function() return v:GetAttribute("realBall") == true end)
        if ok and result then return v end
    end
    for i = 1, #children do
        local v = children[i]
        if v:IsA("BasePart") then
            local ok, mag = pcall(function() return v.AssemblyLinearVelocity.Magnitude end)
            if ok and mag and mag > 15 then return v end
        end
    end
    return nil
end

local function PredictBallPosition(ball, timeAhead)
    if not SETTINGS.PredictPosition then return ball.Position end
    local ok, pos = pcall(function()
        local vel = ball.AssemblyLinearVelocity
        local gravity = workspace.Gravity
        return ball.Position
            + (vel * timeAhead)
            + Vector3.new(0, -0.5 * gravity * timeAhead * timeAhead, 0)
    end)
    return ok and pos or ball.Position
end

local function IsTargeted()
    local char = Player.Character
    if not char then return false end
    local ok1, attr = pcall(function() return char:GetAttribute("Targeted") == true end)
    if ok1 and attr then return true end
    local highlight = char:FindFirstChildWhichIsA("Highlight")
    if highlight and highlight.Parent == char then return true end
    return false
end

local function FireClick()
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end)
end

local function SendClick(isClashing, ball)
    if not SETTINGS.AutoParry or IsParrying then return end
    local now = tick()
    local cd = isClashing and SETTINGS.ClashSpeed or SETTINGS.NormalSpeed
    if not isClashing and LastBallHit == ball and (now - LastClick) < 0.5 then return end
    if (now - LastClick) < cd then return end
    IsParrying = true
    LastClick = now
    LastBallHit = ball
    FireClick()
    if SETTINGS.MultiFireCount > 1 then
        for i = 1, SETTINGS.MultiFireCount - 1 do
            task.delay(SETTINGS.MultiFireDelay * i, function()
                if IsParrying then FireClick() end
            end)
        end
    end
    task.delay(cd, function() IsParrying = false end)
end

