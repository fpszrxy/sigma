-- Auto Parry Settings
getgenv().Aeloe = {
    ["AutoParry"] = true,
    ["PingBased"] = true,
    ["PingBasedOffset"] = 1.95, 
    ["DistanceToParry"] = 0.65,
    ["EmergencyRadius"] = 10,
    ["ClashDistance"] = 22,
    ["ClashSpeed"] = 0.01,
    ["NormalSpeed"] = 0.05,
    ["Visuals"] = true
}

-- Global variable to control auto-spam parry
_G.AutoSpamParryEnabled = false

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Stats = game:GetService("Stats")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Player = Players.LocalPlayer

-- Settings
local SETTINGS = getgenv().Aeloe
local LastClick = 0
local LastBallHit = nil
local IsParrying = false
local frameCounter = 0
local BallsFolder = workspace:FindFirstChild("Balls") or workspace:WaitForChild("Balls", 5)

-- Network Stats
local NetworkStats = Stats:FindFirstChild("Network") 
    and Stats.Network:FindFirstChild("ServerStatsItem") 
    and Stats.Network.ServerStatsItem:FindFirstChild("Data Ping")

-- Visuals
local r, m
if SETTINGS.Visuals then
    r = Instance.new("Part")
    r.Name = "AeloeSmartCircle"
    r.Parent = workspace
    r.Anchored, r.CanCollide = true, false
    r.Transparency, r.Material = 0.3, Enum.Material.Neon
    m = Instance.new("SpecialMesh", r)
    m.MeshId = "rbxassetid://3270017"
end

-- Input Handling
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.L then
        SETTINGS.AutoParry = not SETTINGS.AutoParry
    elseif input.KeyCode == Enum.KeyCode.K then
        AutoTuneSettings()
    elseif input.KeyCode == Enum.KeyCode.P then
        _G.AutoSpamParryEnabled = not _G.AutoSpamParryEnabled
    end
end)

-- Functions

local function GetBall()
    if not BallsFolder then return nil end
    local children = BallsFolder:GetChildren()
    for i, v in pairs(children) do
        if v:GetAttribute("realBall") == true then return v end
    end
    for i, v in pairs(children) do
        if v:IsA("BasePart") and v.AssemblyLinearVelocity.Magnitude > 15 then return v end
    end
    return nil
end

local function IsTargeted()
    if not Player.Character then return false end
    return Player.Character:GetAttribute("Targeted") == true 
        or Player.Character:FindFirstChild("Highlight") ~= nil
end

local function SendClick(isClashing, ball)
    if not SETTINGS.AutoParry or IsParrying then return end
    local now = tick()
    local cd = isClashing and SETTINGS.ClashSpeed or SETTINGS.NormalSpeed
    
    if not isClashing and LastBallHit == ball and (now - LastClick) < 0.5 then return end
    if (now - LastClick) < cd then return end
    
    IsParrying = true
    LastClick = now
    LastBallHit = ball
    
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    task.delay(cd, function() IsParrying = false end)
end

local function UpdateVisuals(root, distance, state)
    if not SETTINGS.Visuals or not r then return end
    r.CFrame = root.CFrame * CFrame.new(0, -2.6, 0) * CFrame.Angles(math.rad(90), 0, 0)
    local targetSize = math.clamp(distance * 0.8, 5, 65)
    m.Scale = m.Scale:Lerp(Vector3.new(targetSize, targetSize, 0.5), 0.5)

    if state == "clash" then
        r.Color = Color3.fromRGB(255, 0, 0)
        r.Transparency = 0.05
    elseif state == "target" then
        r.Color = Color3.fromRGB(0, 255, 255)
        r.Transparency = 0.1
    else
        r.Color = Color3.fromRGB(150, 240, 255)
        r.Transparency = 0.5
    end
end

local function AutoTuneSettings()
    local Char = Player.Character
    if not Char then return end
    local Root = Char:FindFirstChild("HumanoidRootPart")
    if not Root then return end

    local Ball = GetBall()
    if not Ball then return end

    local Ping = (NetworkStats and NetworkStats.Value / 1000) or 0.04
    local Distance = (Ball.Position - Root.Position).Magnitude
    local Speed = Ball.AssemblyLinearVelocity.Magnitude

    SETTINGS.DistanceToParry = Distance * 0.75
    SETTINGS.EmergencyRadius = Distance + 2
    SETTINGS.ClashDistance = Distance * 1.5
    SETTINGS.PingBasedOffset = Ping / 0.04
end

-- Main Loop
RunService.PostSimulation:Connect(function()
    if not SETTINGS.AutoParry then 
        if r then r.Transparency = 1 end
        return 
    end
    
    local Char = Player.Character
    local Root = Char and Char:FindFirstChild("HumanoidRootPart")
    if not Root then 
        if r then r.Transparency = 1 end
        return 
    end

    local Ball = GetBall()
    if not Ball then
        if r then r.Transparency = 1 end
        return
    end

    local BallPos, PlayerPos = Ball.Position, Root.Position
    local Velocity = Ball.AssemblyLinearVelocity
    local Speed = Velocity.Magnitude
    local Distance = (PlayerPos - BallPos).Magnitude
    
    local directionToPlayer = (PlayerPos - BallPos).Unit
    local velocityDirection = Velocity.Unit
    local dot = directionToPlayer:Dot(velocityDirection)

    if dot < 0 then LastBallHit = nil end 

    local Targeted = IsTargeted()
    local IsClashing = Targeted and Distance <= SETTINGS.ClashDistance
    
    frameCounter = frameCounter + 1
    if r and frameCounter % 10 == 0 then 
        UpdateVisuals(Root, Distance, IsClashing and "clash" or (Targeted and "target" or "neutral"))
    end

    if IsClashing then
        SendClick(true, Ball)
    elseif Targeted and dot > 0 then
        local Ping = (NetworkStats and NetworkStats.Value / 1000) or 0.04
        local TimeToHit = Distance / math.max(Speed, 1)
        local PredictionThreshold = SETTINGS.DistanceToParry + (Ping * SETTINGS.PingBasedOffset)
        
        if Speed > 150 then
            PredictionThreshold = PredictionThreshold * 1.15
        end

        if TimeToHit <= PredictionThreshold or Distance <= SETTINGS.EmergencyRadius then
            SendClick(false, Ball)
        end
    end

    -- Auto Spam Parry
    if _G.AutoSpamParryEnabled then
        local autoClickInterval = 0.1 + math.random() / 20 -- Randomize interval slightly to avoid detection
        if tick() - LastClick > autoClickInterval then
            SendClick(false, Ball)
        end
    end

    -- Velocity Display
    if r and frameCounter % 60 == 0 then
        local velocityText = Instance.new("BillboardGui", Player.Character.Head)
        velocityText.Name = "VelocityDisplay"
        velocityText.Adornee = Player.Character.Head
        velocityText.StudsOffset = Vector3.new(0, 2, 0)

        local label = Instance.new("TextLabel", velocityText)
        label.Size = UDim2.new(0, 100, 0, 50)
        label.Position = UDim2.new(0.5, -50, 0, -25)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        label.TextStrokeTransparency = 0.5
        label.Font = Enum.Font.SourceSansBold
        label.TextSize = 18
        label.Text = "Speed: " .. math.floor(Speed) .. " m/s"

        wait(1) -- Show the text for 1 second before removing it
        velocityText:Destroy()
    end
end)

-- Reset on Character Added
Player.CharacterAdded:Connect(function()
    LastBallHit = nil
    IsParrying = false

    -- Recreate visuals
    if SETTINGS.Visuals then
        r = Instance.new("Part")
        r.Name = "AeloeSmartCircle"
        r.Parent = workspace
        r.Anchored, r.CanCollide = true, false
        r.Transparency, r.Material = 0.3, Enum.Material.Neon
        m = Instance.new("SpecialMesh", r)
        m.MeshId = "rbxassetid://3270017"
    end
end)

-- Enhance Player Survival
local function EnhanceSurvival()
    -- Example: Lower health regeneration rate
    local humanoid = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    humanoid.HealthRegenerationRate = 0.1 -- Set to a lower value (e.g., 0.1) to make the player regenerate slower
end

EnhanceSurvival()

-- Auto-Tune Settings when Character is Added
Player.CharacterAdded:Connect(function()
    AutoTuneSettings() -- Automatically tune settings based on current game conditions
    EnhanceSurvival()  -- Enhance player survival
end)
