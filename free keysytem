-- Main parry loop
RunService.PreSimulation:Connect(function(delta)
    -- Frame skip to reduce CPU load and detection risk
    parryFrameSkip = parryFrameSkip + 1
    if parryFrameSkip % 3 ~= 0 then return end

    if not SETTINGS.AutoParry then
        if r then r.Transparency = 1 end
        StopSpam()
        return
    end

    local Char = Player.Character
    local Root = Char and Char:FindFirstChild("HumanoidRootPart")
    if not Root then
        if r then r.Transparency = 1 end
        StopSpam()
        return
    end

    local Ball = GetBall()
    if not Ball then
        if r then r.Transparency = 1 end
        StopSpam()
        return
    end

    local Velocity, Speed
    local ok = pcall(function()
        Velocity = Ball.AssemblyLinearVelocity
        Speed = Velocity.Magnitude
    end)
    if not ok or not Velocity or not Speed then return end
    if Speed < 1 then return end

    local Ping = GetPing()
    UpdateAdaptivePing(Ping)

    local PlayerPos = Root.Position
    local BallPos = Ball.Position

    local PredictedPos = GetPredictedPosition(Ball, Velocity, Ping)
    lastBallVel = Velocity

    local RealDistance = (PlayerPos - BallPos).Magnitude
    local PredictedDistance = (PlayerPos - PredictedPos).Magnitude

    local directionToPlayer = (PlayerPos - BallPos).Unit
    local dot = directionToPlayer:Dot(Velocity.Unit)
    local approachSpeed = dot * Speed

    if approachSpeed <= 0 then
        LastBallHit = nil
        StopSpam()
    end

    local Targeted = IsTargeted()
    local IsClashing = Targeted and RealDistance <= 22

    local shouldSpam = SETTINGS.AutoSpam
        and Targeted
        and dot > 0
        and Speed >= SETTINGS.SpamSpeedThreshold
        and RealDistance <= SETTINGS.SpamDistance

    if shouldSpam then
        StartSpam()
    else
        StopSpam()
    end


    frameCounter = frameCounter + 1
    if frameCounter % 2 == 0 then
        local state = isSpamming and "spam"
            or (IsClashing and "clash")
            or (Targeted and "target")
            or "neutral"
        UpdateVisuals(Root, RealDistance, state)
    end

    if not Targeted or dot <= 0 then return end

    local TimeToHit = RealDistance / math.max(approachSpeed, 1)
    local PredictionThreshold = (SETTINGS.DistanceToParry / 10) + (Ping * adaptivePingOffset)

    if Speed > 150 then
        PredictionThreshold = PredictionThreshold * 1.2
    elseif Speed > 100 then
        PredictionThreshold = PredictionThreshold * 1.1
    end

    if TimeToHit <= PredictionThreshold then
        SendClick(Ball)
    end
end)

