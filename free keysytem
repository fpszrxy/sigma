-- AUTO SPAM SETTINGS
-- ============================================
local SPAM_SPEED_THRESHOLD = 120  -- studs/s to trigger spam
local SPAM_DISTANCE_THRESHOLD = 20 -- studs to trigger spam
local SPAM_INTERVAL = 0.008 -- how fast to spam clicks
local isSpamming = false
local spamConnection = nil

local function StartSpam()
    if isSpamming then return end
    isSpamming = true
    spamConnection = task.spawn(function()
        while isSpamming do
            FireClick()
            task.wait(SPAM_INTERVAL)
        end
    end)
end

local function StopSpam()
    if not isSpamming then return end
    isSpamming = false
    spamConnection = nil
end

